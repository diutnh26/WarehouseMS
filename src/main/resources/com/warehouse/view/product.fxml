<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns:fx="http://javafx.com/fxml" fx:controller="com.warehouse.controller.ProductController">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- Page Header -->
    <VBox spacing="2">
        <Label text="Products" styleClass="page-title"/>
        <Label text="Home / Products" styleClass="breadcrumb-label"/>
    </VBox>

    <!-- Product List Card -->
    <VBox styleClass="recent-card" VBox.vgrow="ALWAYS">
        <!-- Card Header: Title + Search -->
        <HBox alignment="CENTER_LEFT" styleClass="card-title">
            <Label text="Product List" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtSearch" promptText="Search by code or name..." prefWidth="250"
                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E5EF; -fx-padding: 8 14;"/>
        </HBox>

        <!-- Table -->
        <TableView fx:id="tblProducts" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCode" text="Code" prefWidth="110"/>
                <TableColumn fx:id="colName" text="Product Name" prefWidth="200"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="140"/>
                <TableColumn fx:id="colUnit" text="Unit" prefWidth="80"/>
                <TableColumn fx:id="colMinStock" text="Min Stock" prefWidth="100"/>
                <TableColumn fx:id="colCurrentQty" text="Current Qty" prefWidth="110"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Product Details Form -->
    <VBox spacing="16" styleClass="recent-card">
        <Label text="Product Details" styleClass="card-title" 
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 16 20;"/>

        <VBox spacing="16" style="-fx-padding: 0 20 16 20;">
            <!-- Row 1: Code, Name, Category -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="PRODUCT CODE" styleClass="form-label"/>
                    <TextField fx:id="txtProductCode"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="PRODUCT NAME" styleClass="form-label"/>
                    <TextField fx:id="txtProductName"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="CATEGORY" styleClass="form-label"/>
                    <ComboBox fx:id="cmbCategory" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <!-- Row 2: Unit, Min Stock, Description -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="UNIT" styleClass="form-label"/>
                    <TextField fx:id="txtUnit" promptText="Piece"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="MIN STOCK LEVEL" styleClass="form-label"/>
                    <TextField fx:id="txtMinStockLevel" promptText="10"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="DESCRIPTION" styleClass="form-label"/>
                    <TextArea fx:id="txtDescription" prefRowCount="1" maxHeight="36"/>
                </VBox>
            </HBox>

            <!-- Buttons -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Add" onAction="#handleAdd" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="btn-primary"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                <Button text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>