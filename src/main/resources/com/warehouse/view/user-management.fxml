<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns:fx="http://javafx.com/fxml" fx:controller="com.warehouse.controller.UserManagementController">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- Page Header -->
    <VBox spacing="2">
        <Label text="User Management" styleClass="page-title"/>
        <Label text="Home / Users" styleClass="breadcrumb-label"/>
    </VBox>

    <!-- User List Card -->
    <VBox styleClass="recent-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" styleClass="card-title">
            <Label text="Users" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtSearch" promptText="Search users..." prefWidth="250"
                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E5EF; -fx-padding: 8 14;"/>
        </HBox>

        <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="120"/>
                <TableColumn fx:id="colFullName" text="Full Name" prefWidth="160"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="130"/>
                <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                <TableColumn fx:id="colActive" text="Status" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

    <!-- User Details Form -->
    <VBox spacing="16" styleClass="recent-card">
        <Label text="User Details" styleClass="card-title"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 16 20;"/>

        <VBox spacing="16" style="-fx-padding: 0 20 16 20;">
            <!-- Row 1: Username, Password, Full Name -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="USERNAME" styleClass="form-label"/>
                    <TextField fx:id="txtUsername"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="PASSWORD" styleClass="form-label"/>
                    <PasswordField fx:id="txtPassword" promptText="Leave blank to keep"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="FULL NAME" styleClass="form-label"/>
                    <TextField fx:id="txtFullName"/>
                </VBox>
            </HBox>

            <!-- Row 2: Email, Phone, Role -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="EMAIL" styleClass="form-label"/>
                    <TextField fx:id="txtEmail"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="PHONE" styleClass="form-label"/>
                    <TextField fx:id="txtPhone"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="ROLE" styleClass="form-label"/>
                    <ComboBox fx:id="cmbRole" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <!-- Active checkbox -->
            <CheckBox fx:id="chkActive" text="Active" selected="true"/>

            <!-- Buttons -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Add" onAction="#handleAdd" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="btn-primary"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                <Button text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </VBox>
</VBox>