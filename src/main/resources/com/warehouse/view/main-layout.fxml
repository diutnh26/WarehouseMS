<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="main-layout"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.DashboardController">

    <!-- LEFT: Sidebar Navigation -->
    <left>
        <VBox styleClass="sidebar" spacing="3" prefWidth="240">
            <padding><Insets top="15" right="10" bottom="15" left="10"/></padding>

            <Label text="W M S ." styleClass="sidebar-brand"/>
            <Label fx:id="lblUserName" text="User Name" styleClass="sidebar-user"/>
            <Label fx:id="lblUserRole" text="Role" styleClass="sidebar-role"/>

            <Separator/>

            <Label text="MAIN" styleClass="nav-section"/>

            <VBox fx:id="navMenu" spacing="1">
                <Button text="◫  Dashboard"      onAction="#showDashboard"   styleClass="nav-btn" maxWidth="Infinity"/>
                <Button fx:id="btnProducts"    text="◻  Products"     onAction="#showProducts"     styleClass="nav-btn" maxWidth="Infinity"/>
                <Button fx:id="btnCategories"  text="◻  Categories"   onAction="#showCategories"   styleClass="nav-btn" maxWidth="Infinity"/>
                <Button fx:id="btnSuppliers"   text="◻  Suppliers"    onAction="#showSuppliers"    styleClass="nav-btn" maxWidth="Infinity"/>

                <Separator/>
                <Label text="TRANSACTIONS" styleClass="nav-section"/>

                <Button fx:id="btnStockImport" text="↓  Stock Import" onAction="#showStockImport"  styleClass="nav-btn" maxWidth="Infinity"/>
                <Button fx:id="btnStockExport" text="↑  Stock Export" onAction="#showStockExport"  styleClass="nav-btn" maxWidth="Infinity"/>
                <Button fx:id="btnInventory"   text="◻  Inventory"    onAction="#showInventory"    styleClass="nav-btn" maxWidth="Infinity"/>

                <Separator/>
                <Label text="ANALYSIS" styleClass="nav-section"/>

                <Button fx:id="btnReports"     text="◻  Reports"      onAction="#showReports"      styleClass="nav-btn" maxWidth="Infinity"/>
                <Button fx:id="btnUsers"       text="◻  Users"        onAction="#showUsers"        styleClass="nav-btn" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout" onAction="#handleLogout" styleClass="btn-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- CENTER: Content Area (default = dashboard stats) -->
    <center>
        <BorderPane fx:id="contentArea">
            <center>
                <VBox spacing="20" alignment="TOP_LEFT" styleClass="dashboard-content">
                    <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

                    <HBox alignment="CENTER_LEFT">
                        <VBox>
                            <Label text="Dashboard" styleClass="page-title"/>
                            <Label text="Home / Dashboard" styleClass="breadcrumb-label"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox styleClass="stat-card-blue" alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label text="PRODUCTS" styleClass="stat-label"/>
                            <Label fx:id="lblTotalProducts" text="0" styleClass="stat-value"/>
                            <Label text="Active items" styleClass="stat-sub"/>
                        </VBox>
                        <VBox styleClass="stat-card-green" alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label text="SUPPLIERS" styleClass="stat-label"/>
                            <Label fx:id="lblTotalSuppliers" text="0" styleClass="stat-value"/>
                            <Label text="Active partners" styleClass="stat-sub"/>
                        </VBox>
                        <VBox styleClass="stat-card-red" alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label text="LOW STOCK" styleClass="stat-label"/>
                            <Label fx:id="lblLowStock" text="0" styleClass="stat-value"/>
                            <Label text="Need restock" styleClass="stat-sub-danger"/>
                        </VBox>
                        <VBox styleClass="stat-card-yellow" alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label text="TODAY IMPORTS" styleClass="stat-label"/>
                            <Label fx:id="lblTodayImports" text="0" styleClass="stat-value"/>
                            <Label text="Transactions" styleClass="stat-sub"/>
                        </VBox>
                        <VBox styleClass="stat-card-purple" alignment="CENTER" HBox.hgrow="ALWAYS">
                            <Label text="TODAY EXPORTS" styleClass="stat-label"/>
                            <Label fx:id="lblTodayExports" text="0" styleClass="stat-value"/>
                            <Label text="Transactions" styleClass="stat-sub"/>
                        </VBox>
                    </HBox>

                    <!-- Recent Activity Table -->
                    <VBox styleClass="recent-card" VBox.vgrow="ALWAYS">
                        <Label text="Recent Activity" styleClass="card-title"/>
                        <TableView fx:id="tblRecentActivity" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn text="Type" prefWidth="100"/>
                                <TableColumn text="Date" prefWidth="120"/>
                                <TableColumn text="Products" prefWidth="250"/>
                                <TableColumn text="Created By" prefWidth="150"/>
                                <TableColumn text="Status" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </center>
</BorderPane>
