<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.warehouse.controller.SupplierController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Supplier Management" styleClass="page-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="txtSearch" promptText="Search by name, contact, phone..." prefWidth="300"/>
    </HBox>

    <TableView fx:id="tblSuppliers" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="colName" text="Supplier Name" prefWidth="180"/>
            <TableColumn fx:id="colContact" text="Contact Person" prefWidth="140"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="120"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="160"/>
            <TableColumn fx:id="colAddress" text="Address" prefWidth="200"/>
        </columns>
    </TableView>

    <TitledPane text="Supplier Details" collapsible="false">
        <GridPane hgap="10" vgap="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <Label text="Supplier Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="txtSupplierName" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

            <Label text="Contact Person:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="txtContactPerson" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="200"/>

            <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="txtPhone" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="txtEmail" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextArea fx:id="txtAddress" GridPane.columnIndex="1" GridPane.rowIndex="2"
                      GridPane.columnSpan="3" prefHeight="50"/>
        </GridPane>
    </TitledPane>

    <HBox spacing="10">
        <Button text="Add" onAction="#handleAdd" styleClass="btn-primary"/>
        <Button text="Update" onAction="#handleUpdate" styleClass="btn-primary"/>
        <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
        <Button text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
    </HBox>
</VBox>
