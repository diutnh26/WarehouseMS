<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.warehouse.controller.StockImportController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Stock Import" styleClass="page-title"/>

    <SplitPane dividerPositions="0.45" VBox.vgrow="ALWAYS">
        <!-- Left: Import history -->
        <VBox spacing="8">
            <Label text="Import History" styleClass="section-label"/>
            <TableView fx:id="tblImports" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colImportId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="140"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                    <TableColumn fx:id="colCreatedBy" text="Created By" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Right: New import form -->
        <VBox spacing="10">
            <padding><Insets top="10" right="15" bottom="10" left="15"/></padding>
            <Label text="New Import" styleClass="section-label"/>

            <GridPane hgap="10" vgap="8">
                <Label text="Supplier:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cmbSupplier" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

                <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <DatePicker fx:id="dpImportDate" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Notes:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextArea fx:id="txtNotes" GridPane.columnIndex="1" GridPane.rowIndex="2" prefHeight="40"/>
            </GridPane>

            <Separator/>

            <Label text="Add Product Line:" styleClass="section-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <ComboBox fx:id="cmbProduct" promptText="Select product" prefWidth="180"/>
                <TextField fx:id="txtQuantity" promptText="Qty" prefWidth="70"/>
                <TextField fx:id="txtUnitPrice" promptText="Unit Price" prefWidth="100"/>
                <Button text="+ Add" onAction="#handleAddLine" styleClass="btn-primary"/>
                <Button text="- Remove" onAction="#handleRemoveLine" styleClass="btn-danger"/>
            </HBox>

            <TableView fx:id="tblDetails" prefHeight="150" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDetailProduct" text="Product" prefWidth="180"/>
                    <TableColumn fx:id="colDetailQty" text="Qty" prefWidth="60"/>
                    <TableColumn fx:id="colDetailPrice" text="Unit Price" prefWidth="90"/>
                    <TableColumn fx:id="colDetailTotal" text="Total" prefWidth="90"/>
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button text="Save Import" onAction="#handleSaveImport" styleClass="btn-primary"/>
                <Button text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </SplitPane>
</VBox>
