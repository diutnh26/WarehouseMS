<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.warehouse.controller.ReportController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Reports" styleClass="page-title"/>

    <TabPane VBox.vgrow="ALWAYS">
        <!-- Tab 1: Movement Report by Date -->
        <Tab text="Inventory Movement Report" closable="false">
            <VBox spacing="10">
                <padding><Insets top="15" right="10" bottom="10" left="10"/></padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="From:"/>
                    <DatePicker fx:id="dpStartDate"/>
                    <Label text="To:"/>
                    <DatePicker fx:id="dpEndDate"/>
                    <Button text="Generate Report" onAction="#handleGenerateMovementReport" styleClass="btn-primary"/>
                </HBox>

                <TableView fx:id="tblMovementReport" VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>

        <!-- Tab 2: Product Movement History -->
        <Tab text="Product Movement History" closable="false">
            <VBox spacing="10">
                <padding><Insets top="15" right="10" bottom="10" left="10"/></padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Product:"/>
                    <ComboBox fx:id="cmbProduct" prefWidth="300"/>
                    <Button text="View History" onAction="#handleGenerateProductHistory" styleClass="btn-primary"/>
                </HBox>

                <TableView fx:id="tblProductHistory" VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
