<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns:fx="http://javafx.com/fxml" fx:controller="com.warehouse.controller.InventoryController">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Inventory Overview" styleClass="page-title"/>
            <Label text="Home / Inventory" styleClass="breadcrumb-label"/>
        </VBox>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <!-- Filter Bar -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="Search by code or name..." prefWidth="280"
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E5EF; -fx-padding: 8 14;"/>
        <CheckBox fx:id="chkLowStockOnly" text="Low stock only"/>
    </HBox>

    <!-- Inventory Table Card -->
    <VBox styleClass="recent-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="tblInventory" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCode" text="Code" prefWidth="100"/>
                <TableColumn fx:id="colName" text="Product Name" prefWidth="200"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="140"/>
                <TableColumn fx:id="colUnit" text="Unit" prefWidth="70"/>
                <TableColumn fx:id="colCurrentQty" text="Current Qty" prefWidth="100"/>
                <TableColumn fx:id="colMinStock" text="Min Stock" prefWidth="90"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                <TableColumn fx:id="colLastUpdated" text="Last Updated" prefWidth="120"/>
            </columns>
        </TableView>

        <!-- Legend -->
        <HBox spacing="20" style="-fx-padding: 10 20;">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Region style="-fx-background-color: #10B981; -fx-min-width: 10; -fx-min-height: 10; -fx-background-radius: 5;"/>
                <Label text="In Stock" style="-fx-text-fill: #6B7A99; -fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Region style="-fx-background-color: #F59E0B; -fx-min-width: 10; -fx-min-height: 10; -fx-background-radius: 5;"/>
                <Label text="Low Stock" style="-fx-text-fill: #6B7A99; -fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Region style="-fx-background-color: #EF4444; -fx-min-width: 10; -fx-min-height: 10; -fx-background-radius: 5;"/>
                <Label text="Out of Stock" style="-fx-text-fill: #6B7A99; -fx-font-size: 12px;"/>
            </HBox>
        </HBox>
    </VBox>
</VBox>