<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.warehouse.controller.InventoryController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Inventory Overview" styleClass="page-title"/>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="txtSearch" promptText="Search by code or name..." prefWidth="280"/>
        <CheckBox fx:id="chkLowStockOnly" text="Low stock only"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="tblInventory" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode" text="Code" prefWidth="90"/>
            <TableColumn fx:id="colName" text="Product Name" prefWidth="190"/>
            <TableColumn fx:id="colCategory" text="Category" prefWidth="110"/>
            <TableColumn fx:id="colUnit" text="Unit" prefWidth="60"/>
            <TableColumn fx:id="colCurrentQty" text="Current Qty" prefWidth="90"/>
            <TableColumn fx:id="colMinStock" text="Min Stock" prefWidth="80"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
            <TableColumn fx:id="colLastUpdated" text="Last Updated" prefWidth="140"/>
        </columns>
    </TableView>

    <HBox spacing="15" styleClass="legend-bar">
        <Label text="Legend:" style="-fx-font-weight: bold;"/>
        <Label text="■ In Stock" style="-fx-text-fill: #28a745;"/>
        <Label text="■ Low Stock" style="-fx-text-fill: #ffc107;"/>
        <Label text="■ Out of Stock" style="-fx-text-fill: #dc3545;"/>
    </HBox>
</VBox>
