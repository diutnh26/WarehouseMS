<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns:fx="http://javafx.com/fxml" fx:controller="com.warehouse.controller.CategoryController">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <!-- Page Header -->
    <VBox spacing="2">
        <Label text="Categories" styleClass="page-title"/>
        <Label text="Home / Categories" styleClass="breadcrumb-label"/>
    </VBox>

    <!-- Split View: Table + Form side by side -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Left: Category List -->
        <VBox styleClass="recent-card" HBox.hgrow="ALWAYS">
            <Label text="Category List" styleClass="card-title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 16 20;"/>
            <TableView fx:id="tblCategories" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName" text="Category Name" prefWidth="200"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="300"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Right: Category Details Form -->
        <VBox spacing="16" styleClass="recent-card" prefWidth="400" minWidth="350">
            <Label text="Category Details" styleClass="card-title"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 16 20;"/>

            <VBox spacing="16" style="-fx-padding: 0 20 16 20;">
                <VBox spacing="6">
                    <Label text="CATEGORY NAME" styleClass="form-label"/>
                    <TextField fx:id="txtCategoryName"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="DESCRIPTION" styleClass="form-label"/>
                    <TextArea fx:id="txtDescription" prefRowCount="3"/>
                </VBox>

                <!-- Buttons -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Add" onAction="#handleAdd" styleClass="btn-primary"/>
                    <Button text="Update" onAction="#handleUpdate" styleClass="btn-primary"/>
                    <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                    <Button text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>